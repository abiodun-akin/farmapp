# =============================================================
# farmapp/.env.example — Frontend environment template
#
# TWO usage modes:
#
# 1. Direct dev (npm run dev outside Docker):
#    Copy to .env.local — Vite hits the backend directly on :8888
#    VITE_API_URL=http://localhost:8888/api
#
# 2. Docker dev (docker compose up from root):
#    Env vars are injected by docker-compose.yml from root .env
#    Nginx proxies /api/ → connectapi:8888 internally
#    VITE_API_URL=http://localhost:8888/api  (same, Vite dev server proxies)
#
# 3. Production (Render static site):
#    VITE_API_URL is set from the backend service's RENDER_EXTERNAL_URL
#    See render.yaml — no .env file needed on Render
# =============================================================

VITE_API_URL=http://localhost:8888/api
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
